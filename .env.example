# Supabase Configuration
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"
VITE_SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Application URL
APP_URL="http://localhost:3000"

# Note: Meta Pixel ID is loaded dynamically from the `settings` table (payment_methods.meta_pixel_id).
# For Conversions API (CAPI), set the following secrets in your Supabase project:
# - META_PIXEL_ID
# - META_CAPI_ACCESS_TOKEN
# - META_TEST_EVENT_CODE (optional, for testing in Events Manager)

